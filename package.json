{
  "name": "eduflow-frontend",
  "version": "1.0.0",
  "description": "Frontend build tooling for EduFlow CRM (Tailwind CSS)",
  "scripts": {
    "build:css": "tailwindcss -i ./src/main/frontend/tailwind.css -o ./src/main/resources/static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/main/frontend/tailwind.css -o ./src/main/resources/static/css/tailwind.css --watch",
    "build:icons": "node -e \"const fs=require('fs'),r=require.resolve; fs.copyFileSync(r('lucide/dist/umd/lucide.min.js'),'./src/main/resources/static/js/lucide.js'); fs.copyFileSync(r('lucide/dist/umd/lucide.min.js.map'),'./src/main/resources/static/js/lucide.min.js.map');\"",
    "build:htmx": "node -e \"require('fs').copyFileSync(require.resolve('htmx.org/dist/htmx.min.js'), './src/main/resources/static/js/htmx.min.js')\"",
    "build:toast": "node -e \"const fs=require('fs'),r=require.resolve; fs.copyFileSync(r('toastify-js/src/toastify.js'),'./src/main/resources/static/js/toastify.js'); fs.copyFileSync(r('toastify-js/src/toastify.css'),'./src/main/resources/static/css/toastify.css');\"",
    "build": "npm run build:css && npm run build:icons && npm run build:htmx && npm run build:toast"
  },
  "dependencies": {
    "htmx.org": "^2.0.4",
    "lucide": "^0.460.0",
    "toastify-js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "tailwindcss": "^3.4.17"
  }
}
